# ---------- LakeBase backend ----------
LAKEBASE_BACKEND=postgres

# ---------- LakeBase / Postgres ----------
LAKEBASE_HOST=
LAKEBASE_PORT=5432
LAKEBASE_DB=
LAKEBASE_USER=
LAKEBASE_PASSWORD=
LAKEBASE_SSLMODE=require

# ---------- LakeBase / DuckDB ----------
LAKEBASE_DUCKDB_PATH=./lakebase.duckdb

# ---------- Databricks / Unity Catalog ----------
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_WAREHOUSE_ID=
DATABRICKS_CATALOG=
DATABRICKS_SCHEMA=

# ---------- Optional rule table names ----------
RULES_ACRONYM_TABLE=governance.acronym_dictionary
RULES_NAMING_TABLE=governance.naming_rules

# ---------- Git AST versioning ----------
GIT_AST_REPO_PATH=
GIT_AST_BRANCH=
GIT_AST_REMOTE=origin

# ---------- App ----------
APP_ENV=dev
LOG_LEVEL=INFO

# ---------- Rate limits (conservative defaults) ----------
RATE_LIMIT_AUTH_LIMIT_PER_MIN=10
RATE_LIMIT_AUTH_BURST=20
RATE_LIMIT_GENERATION_USER_LIMIT_PER_10M=5
RATE_LIMIT_GENERATION_WORKSPACE_LIMIT_PER_HOUR=20
RATE_LIMIT_REVIEW_ACTIONS_USER_LIMIT_PER_MIN=30
RATE_LIMIT_EXPORTS_USER_LIMIT_PER_HOUR=20

# ---------- Webhook signature verification ----------
# Provider-specific: WEBHOOK_SECRET_STRIPE / WEBHOOK_SECRET_SQUARESPACE
# Fallback used when provider-specific secret not set:
COACHING_WEBHOOK_SECRET=
